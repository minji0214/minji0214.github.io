---
// Resume page with isolated styles - no global CSS imports
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>전민지 - Product-Focused Frontend Engineer</title>
		<style is:global>
			@import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css");
			@import url("https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap");

			/* Reset all styles for resume page */
			html,
			body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
			}

			:root {
				--ink: #000000;
				--charcoal: #1a1a1a;
				--dark-gray: #333333;
				--medium-gray: #666666;
				--stone: #999999;
				--light-gray: #e5e5e5;
				--pale-gray: #f5f5f5;
				--white: #ffffff;
				--accent: #ff6f0f;
				--accent-dark: #e55f0e;
				--border: #e0e0e0;
			}

			@media print {
				/* 배경색 출력 강제 */
				* {
					-webkit-print-color-adjust: exact;
					print-color-adjust: exact;
				}

				@page {
					margin: 12mm;
				}

				.resume-page {
					background: var(--white) !important;
				}

				.resume-page .container {
					max-width: none;
					box-shadow: none;
				}

				.resume-page .header {
					padding: 14px 0 12px;
				}

				.resume-page .content {
					padding: 16px 0 0;
				}

				.resume-page .section {
					margin-bottom: 16px;
				}

				.resume-page .experience-item,
				.resume-page .project-item {
					break-inside: avoid;
					page-break-inside: avoid;
				}

				.resume-page .section-header {
					break-after: avoid;
					page-break-after: avoid;
				}
			}

			.resume-page * {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			.resume-page {
				font-family:
					"Pretendard",
					-apple-system,
					BlinkMacSystemFont,
					system-ui,
					sans-serif !important;
				font-weight: 400 !important;
				line-height: 1.6 !important;
				color: var(--ink) !important;
				background: var(--pale-gray) !important;
				min-height: 100vh !important;
				margin: 0 !important;
				padding: 0 !important;
			}

			.resume-page .container {
				max-width: 800px;
				margin: 0 auto;
				background: var(--white);
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
			}

			/* Minimal CV Header */
			.resume-page .header {
				display: block;
				padding: 28px 40px 18px;
				border-bottom: 2px solid var(--accent);
			}

			.resume-page .header-left {
				display: flex;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 14px;
				margin-bottom: 6px;
				padding: 0;
				background: transparent;
			}

			.resume-page .header-left::before {
				display: none;
			}

			.resume-page .name {
				font-family: "Archivo", sans-serif;
				font-size: 30px;
				font-weight: 800;
				color: var(--ink);
				letter-spacing: -0.02em;
				margin: 0;
			}

			.resume-page .title {
				font-size: 13px;
				font-weight: 500;
				color: var(--accent);
				letter-spacing: 0.02em;
				opacity: 1;
			}

			.resume-page .years-indicator {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				margin-top: 0;
				margin-left: auto;
			}

			.resume-page .years-dot {
				width: 6px;
				height: 6px;
				background: var(--accent);
				border-radius: 50%;
			}

			.resume-page .years-text {
				color: var(--medium-gray);
				font-size: 12px;
				font-weight: 500;
				opacity: 1;
			}

			.resume-page .header-right {
				padding: 0;
				background: transparent;
				margin-top: 6px;
				display: block;
			}

			.resume-page .contact-list {
				display: flex;
				flex-direction: row;
				flex-wrap: wrap;
				gap: 14px;
			}

			.resume-page .contact-item {
				display: flex;
				align-items: center;
				gap: 5px;
				font-size: 12px;
				color: var(--medium-gray);
			}

			.resume-page .contact-icon {
				width: 14px;
				height: 14px;
				background: transparent;
				border-radius: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
				border: none;
			}

			.resume-page .contact-icon svg {
				width: 13px;
				height: 13px;
				stroke: var(--medium-gray);
			}

			.resume-page .contact-text {
				color: var(--charcoal);
				text-decoration: none;
				transition: color 0.2s ease;
				font-size: 12px;
			}

			.resume-page .contact-text:hover {
				color: var(--accent);
			}

			/* Main Content */
			.resume-page .content {
				padding: 24px 40px 32px;
			}

			/* About Section - minimal */
			.resume-page .about-section {
				margin-bottom: 28px;
				padding: 0;
				background: transparent;
				border-left: none;
				position: relative;
			}

			.resume-page .about-text {
				font-size: 14px;
				line-height: 1.55;
				color: var(--ink);
				font-weight: 600;
				margin: 0;
				letter-spacing: -0.01em;
			}

			.resume-page .about-text strong {
				font-weight: 700;
				color: var(--accent);
			}

			.resume-page .about-body {
				font-size: 13px;
				line-height: 1.7;
				color: var(--charcoal);
				margin-top: 8px;
			}

			.resume-page .about-list {
				list-style: none;
				padding: 0;
				margin: 18px 0 0 0;
			}

			.resume-page .about-list li {
				position: relative;
				padding-left: 14px;
				margin-bottom: 6px;
				font-size: 14px;
				line-height: 1.65;
				color: var(--charcoal);
			}

			.resume-page .about-list li:last-child {
				margin-bottom: 0;
			}

			.resume-page .about-list li::before {
				content: "·";
				position: absolute;
				left: 2px;
				top: -2px;
				color: var(--medium-gray);
				font-weight: 700;
				font-size: 18px;
			}

			.resume-page .about-list strong {
				font-weight: 700;
				color: var(--ink);
			}

			/* Section Headers - minimal */
			.resume-page .section {
				margin-bottom: 24px;
			}

			.resume-page .section--projects {
				margin-top: 0;
			}

			.resume-page .section-header {
				display: flex;
				align-items: baseline;
				gap: 10px;
				margin-bottom: 14px;
				padding-bottom: 6px;
				border-bottom: 1px solid var(--light-gray);
				position: relative;
			}

			.resume-page .section-number {
				width: auto;
				height: auto;
				background: transparent;
				color: var(--accent);
				border-radius: 0;
				display: inline;
				font-weight: 700;
				font-size: 12px;
				margin-right: 0;
				font-family: "Archivo", sans-serif;
				letter-spacing: 0.04em;
			}

			.resume-page .section-title {
				font-family: "Archivo", sans-serif;
				font-size: 15px;
				font-weight: 700;
				color: var(--ink);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			/* Experience Cards */
			.resume-page .experience-item {
				display: grid;
				grid-template-columns: 130px 1fr;
				gap: 24px;
				margin-bottom: 18px;
				padding: 0;
				background: transparent;
				border: none;
				transition: none;
			}

			.resume-page .experience-item:hover {
				transform: none;
				box-shadow: none;
			}

			.resume-page .experience-period {
				padding-top: 2px;
			}

			.resume-page .experience-date {
				font-size: 12px;
				font-weight: 600;
				color: var(--accent);
				letter-spacing: 0;
			}

			.resume-page .experience-duration {
				font-size: 11px;
				color: var(--stone);
				margin-top: 2px;
			}

			.resume-page .experience-content {
				padding-top: 0;
			}

			.resume-page .experience-title {
				font-size: 15px;
				font-weight: 700;
				color: var(--ink);
				margin-bottom: 2px;
			}

			.resume-page .experience-company {
				font-size: 15px;
				color: var(--ink);
				font-weight: 700;
				margin-bottom: 6px;
			}

			.resume-page .experience-description {
				font-size: 12px;
				color: var(--medium-gray);
				margin-bottom: 8px;
				line-height: 1.55;
				font-style: italic;
			}

			.resume-page .experience-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.resume-page .experience-list li {
				position: relative;
				padding-left: 12px;
				margin-bottom: 3px;
				font-size: 13px;
				line-height: 1.6;
				color: var(--charcoal);
			}

			.resume-page .experience-list li:last-child {
				margin-bottom: 0;
			}

			.resume-page .experience-list li::before {
				content: "·";
				position: absolute;
				left: 2px;
				top: -2px;
				color: var(--medium-gray);
				font-weight: 700;
				font-size: 18px;
			}

			.resume-page .experience-list strong {
				font-weight: 700;
				color: var(--ink);
			}

			/* Skills - inline minimal */
			.resume-page .skills-container {
				display: grid;
				grid-template-columns: 130px 1fr;
				gap: 16px 24px;
				row-gap: 6px;
			}

			.resume-page .skill-card {
				display: contents;
				padding: 0;
				background: transparent;
				border: none;
			}

			.resume-page .skill-card::before {
				display: none;
			}

			.resume-page .skill-card-title {
				font-size: 12px;
				font-weight: 700;
				color: var(--accent);
				margin: 0;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				padding-top: 2px;
			}

			.resume-page .skill-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 5px;
			}

			.resume-page .skill-tag {
				padding: 2px 8px;
				background: transparent;
				color: var(--charcoal);
				border-radius: 3px;
				font-size: 12px;
				font-weight: 500;
				border: 1px solid var(--light-gray);
				transition: none;
			}

			.resume-page .skill-tag:hover {
				background: transparent;
				color: var(--accent);
				border-color: var(--accent);
				transform: none;
			}

			/* Projects - minimal */
			.resume-page .project-item {
				padding: 0 0 0 14px;
				background: transparent;
				margin-bottom: 14px;
				position: relative;
				border-left: 2px solid var(--accent);
			}

			.resume-page .project-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 4px;
				gap: 12px;
			}

			.resume-page .project-title {
				font-size: 14px;
				font-weight: 700;
				color: var(--ink);
			}

			.resume-page .project-period {
				font-size: 11px;
				color: var(--stone);
				font-weight: 500;
				flex-shrink: 0;
			}

			.resume-page .project-tech {
				display: flex;
				flex-wrap: wrap;
				gap: 4px;
				margin-bottom: 6px;
			}

			.resume-page .tech-chip {
				display: inline-block;
				font-size: 11px;
				color: var(--medium-gray);
				font-weight: 500;
				background: transparent;
				border: none;
				padding: 0;
				border-radius: 0;
				letter-spacing: 0;
			}

			.resume-page .tech-chip:not(:last-child)::after {
				content: " ·";
				margin-left: 2px;
				color: var(--light-gray);
			}

			.resume-page .project-description {
				font-size: 13px;
				color: var(--charcoal);
				line-height: 1.6;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.resume-page .project-description li {
				position: relative;
				padding-left: 12px;
				margin-bottom: 3px;
			}

			.resume-page .project-description li:last-child {
				margin-bottom: 0;
			}

			.resume-page .project-description li::before {
				content: "·";
				position: absolute;
				left: 2px;
				top: -2px;
				color: var(--medium-gray);
				font-weight: 700;
				font-size: 18px;
			}

			.resume-page .project-description strong {
				font-weight: 700;
				color: var(--ink);
			}

			/* Education - minimal */
			.resume-page .education-item {
				padding: 0;
				background: transparent;
				border: none;
				display: grid;
				grid-template-columns: 130px 1fr;
				gap: 24px;
				align-items: baseline;
			}

			.resume-page .education-icon {
				display: none;
			}

			.resume-page .education-content {
				flex: 1;
			}

			.resume-page .education-degree {
				font-size: 13px;
				font-weight: 700;
				color: var(--ink);
				margin-bottom: 2px;
			}

			.resume-page .education-school {
				font-size: 12px;
				color: var(--charcoal);
				margin-bottom: 0;
			}

			.resume-page .education-date {
				font-size: 12px;
				color: var(--accent);
				font-weight: 600;
			}

			/* Activities - minimal */
			.resume-page .activities-list {
				display: flex;
				flex-direction: column;
				gap: 4px;
			}

			.resume-page .activity-item {
				padding: 4px 0 4px 12px;
				background: transparent;
				border-left: 2px solid var(--accent);
				font-size: 13px;
				color: var(--charcoal);
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
				text-decoration: none;
				transition: color 0.2s ease;
			}

			.resume-page a.activity-item::after {
				content: "↗";
				flex-shrink: 0;
				color: var(--accent);
				font-size: 16px;
				font-weight: 700;
				transition: transform 0.2s ease;
			}

			.resume-page a.activity-item:hover {
				background: transparent;
				color: var(--accent-dark);
				transform: none;
			}

			.resume-page a.activity-item:hover::after {
				transform: translate(2px, -2px);
			}

			/* Testimonials Section */
			.resume-page .testimonials-section {
				margin-bottom: 56px;
			}

			.resume-page .testimonial-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 20px;
			}

			.resume-page .testimonial-card {
				padding: 24px;
				background: var(--white);
				border: 1px solid var(--light-gray);
				border-left: 3px solid var(--accent);
				position: relative;
			}

			.resume-page .testimonial-content {
				font-size: 13px;
				line-height: 1.7;
				color: var(--charcoal);
				margin-bottom: 16px;
				font-style: italic;
			}

			.resume-page .testimonial-author {
				display: flex;
				align-items: center;
				gap: 8px;
			}

			.resume-page .testimonial-role {
				font-size: 13px;
				font-weight: 700;
				color: var(--ink);
			}

			.resume-page .testimonial-company {
				font-size: 12px;
				color: var(--stone);
			}

			.resume-page .testimonial-divider {
				width: 20px;
				height: 1px;
				background: var(--light-gray);
			}

			/* Responsive */
			@media (max-width: 768px) {
				.resume-page .experience-item {
					grid-template-columns: 1fr;
					gap: 16px;
				}

				.resume-page .skills-container {
					grid-template-columns: 1fr;
				}
			}

			/* Mobile (small phones, 360px~480px) */
			@media (max-width: 480px) {
				.resume-page .container {
					box-shadow: none;
				}

				/* Header: stack vertically */
				.resume-page .header {
					grid-template-columns: 1fr;
					min-height: auto;
				}
				.resume-page .header-left {
					padding: 28px 20px;
				}
				.resume-page .header-left::before {
					display: none;
				}
				.resume-page .name {
					font-size: 32px;
					margin-bottom: 8px;
				}
				.resume-page .title {
					font-size: 14px;
				}
				.resume-page .years-indicator {
					margin-top: 16px;
				}
				.resume-page .header-right {
					padding: 24px 20px;
				}
				.resume-page .contact-list {
					gap: 14px;
				}
				.resume-page .contact-text {
					font-size: 13px;
					word-break: break-all;
				}

				/* Content */
				.resume-page .content {
					padding: 24px 16px;
				}

				/* About */
				.resume-page .about-section {
					padding: 20px;
					margin-bottom: 36px;
				}
				.resume-page .about-text {
					font-size: 15px;
					line-height: 1.55;
				}
				.resume-page .about-text br {
					display: none;
				}
				.resume-page .about-body {
					font-size: 13px;
					line-height: 1.7;
				}
				.resume-page .about-body br {
					display: none;
				}

				/* Section */
				.resume-page .section {
					margin-bottom: 36px;
				}
				.resume-page .section-header {
					margin-bottom: 24px;
				}
				.resume-page .section-number {
					width: 32px;
					height: 32px;
					font-size: 13px;
					margin-right: 12px;
				}
				.resume-page .section-title {
					font-size: 17px;
				}

				/* Experience */
				.resume-page .experience-item {
					padding: 18px;
					gap: 12px;
					margin-bottom: 20px;
				}
				.resume-page .experience-item:hover {
					transform: none;
				}
				.resume-page .experience-period {
					display: flex;
					align-items: baseline;
					gap: 12px;
					padding-top: 0;
					flex-wrap: wrap;
				}
				.resume-page .experience-duration {
					margin-top: 0;
				}
				.resume-page .experience-title,
				.resume-page .experience-company {
					font-size: 16px;
				}

				/* Project */
				.resume-page .project-item {
					padding: 18px;
				}
				.resume-page .project-header {
					flex-direction: column;
					align-items: flex-start;
					gap: 4px;
				}
				.resume-page .project-title {
					font-size: 16px;
				}

				/* Skills */
				.resume-page .skill-card {
					padding: 18px;
				}

				/* Education */
				.resume-page .education-item {
					gap: 16px;
					padding: 18px;
				}
				.resume-page .education-icon {
					width: 48px;
					height: 48px;
				}
				.resume-page .education-icon svg {
					width: 24px;
					height: 24px;
				}

				/* Activities */
				.resume-page .activities-list {
					grid-template-columns: 1fr;
				}

				/* Testimonials */
				.resume-page .testimonial-grid {
					grid-template-columns: 1fr;
				}
				.resume-page .testimonial-card {
					padding: 18px;
				}
			}
		</style>
	</head>
	<body>
		<div class="resume-page">
			<div class="container">
				<!-- Header -->
				<header class="header">
					<div class="header-left">
						<h1 class="name">전민지</h1>
						<div class="title">Product-Focused Frontend Engineer</div>
						<div class="years-indicator">
							<div class="years-dot"></div>
							<span class="years-text">3+ Years Experience</span>
						</div>
					</div>

					<div class="header-right">
						<div class="contact-list">
							<div class="contact-item">
								<div class="contact-icon">
									<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="1.5"
											d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
										></path>
									</svg>
								</div>
								<a href="mailto:minji0214@gmail.com" class="contact-text"
									>minji0214@gmail.com</a
								>
